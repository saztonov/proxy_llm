# =========================================================================
# proxy_llm — пример конфигурации.
# Скопировать в /etc/proxy_llm/.env (chown root:proxy_llm, chmod 640).
# Все секреты ОБЯЗАТЕЛЬНО заменить перед запуском.
# =========================================================================

# === Inbound ===
LISTEN_HOST=127.0.0.1
LISTEN_PORT=3000
PROXY_INBOUND_TOKEN=replace-with-openssl-rand-hex-32
BODY_LIMIT_BYTES=27262976

# === OpenRouter ===
OPENROUTER_API_KEY=sk-or-v1-replace-with-real-key
OPENROUTER_BASE_URL=https://openrouter.ai
OPENROUTER_MODEL=google/gemini-2.5-flash
# Comma-separated; пусто = одиночная model в payload, иначе массив models.
# Применяется, только когда модель не выбрана явно (клиент не прислал model, прислал
# заглушку proxy/default/auto, либо его allowedModels пуст). Явный выбор модели клиентом
# fallback-цепочку отключает.
OPENROUTER_FALLBACK_MODELS=
OPENROUTER_HTTP_REFERER=https://passdesk.your-domain.example
OPENROUTER_X_TITLE=PassDesk OCR via proxy_llm

# === Deadlines / Retry ===
REQUEST_DEADLINE_MS=190000
UPSTREAM_ATTEMPT_TIMEOUT_MS=160000
UPSTREAM_MAX_ATTEMPTS=2
MIN_REMAINING_MS=10000
UPSTREAM_RESPONSE_BODY_LIMIT_BYTES=2097152

# === Queue / Dedup ===
# QUEUE_CONCURRENCY — общий потолок одновременных upstream-вызовов (global).
# QUEUE_MAX_PENDING — общий потолок admitted-запросов (память/back-pressure).
# Multi-tenant рекомендуемый старт: QUEUE_CONCURRENCY=3, QUEUE_MAX_PENDING=6.
QUEUE_CONCURRENCY=1
QUEUE_MAX_PENDING=10
MAX_ACTIVE_DEDUP_KEYS=1000
GRACEFUL_DRAIN_MS=60000

# === Multi-tenant (реестр клиентов) ===
# CLIENTS_CONFIG_PATH НЕ задан → single-tenant legacy из PROXY_INBOUND_TOKEN (текущее поведение).
# Задан явно, но файл отсутствует/битый → fail-fast (сервис не стартует).
# Пример файла — deploy/clients.example.json.
# CLIENTS_CONFIG_PATH=/etc/proxy_llm/clients.json
CLIENT_DEFAULT_MAX_CONCURRENCY=1
CLIENT_DEFAULT_MAX_PENDING=10
# CSV белого списка моделей для клиентов БЕЗ явного allowedModels в clients.json:
#   пусто  = клиент НЕ выбирает модель (форс defaultModel) — безопасный дефолт, как раньше;
#   список = клиент может прислать model из него, иначе 400 model_not_allowed;
#   *      = любая модель OpenRouter (снимает контроль над роутингом и биллингом).
# Заглушки proxy/default/auto в поле model всегда означают «модель не выбираю» → defaultModel.
#
# ВНИМАНИЕ: `*` ОЖИВЛЯЕТ поле model у клиентов, которые уже шлют реальное имя модели
# (PassDesk шлёт OCR_OPENROUTER_MODEL): их роутинг и биллинг молча изменятся, а fallback-цепочка
# отключится. Включать по чек-листу docs/vps-update.md §4a: сначала точечно тем, кто доработан,
# глобальный `*` — последним шагом. Удержать клиента на старом поведении можно только явным
# "allowedModels": [] в его записи clients.json — он перебивает этот дефолт.
CLIENT_DEFAULT_ALLOWED_MODELS=

# === Storage ===
DB_PATH=/var/lib/proxy_llm/prod.db

# === Dashboard ===
DASHBOARD_USER=admin
DASHBOARD_BASIC_AUTH_PASS=replace-with-strong-password

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# === Alerts thresholds ===
ALERT_ERROR_STREAK_THRESHOLD=5
ALERT_ERROR_RATE_THRESHOLD=0.30
ALERT_ERROR_RATE_WINDOW=50
ALERT_LONG_REQUEST_MS=150000
ALERT_DISK_FREE_MIN_BYTES=524288000

# === Logging ===
LOG_LEVEL=info
NODE_ENV=production
